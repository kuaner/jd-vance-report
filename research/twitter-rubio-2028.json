    "id": "1952864914550210685",
    "text": "BREAKING: 🚨  Trump suggests a Vance/Rubio ticket for 2028. \n\nTHOUGHTS?",
    "author": {
      "id": "727648168171610112",
      "name": "E X X ➠A L E R T S",
      "screenName": "ExxAlerts",
      "profileImageUrl": "https://pbs.twimg.com/profile_images/1974049354655621120/fAt47Ei4_normal.jpg",
      "verified": true
    },
    "metrics": {
      "likes": 2494,
      "retweets": 104,
      "replies": 771,
      "quotes": 55,
      "views": 210776,
      "bookmarks": 21
    },
    "createdAt": "Tue Aug 05 22:50:52 +0000 2025",
    "createdAtLocal": "2025-08-06 06:50",
    "createdAtISO": "2025-08-05T22:50:52+00:00",
    "media": [],
